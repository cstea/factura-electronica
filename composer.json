{
    "name": "stea/factura-electronica",
    "description": "Native Costa Rica factura electrónica (v4.4): build, XAdES-EPES sign, and submit comprobantes.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-dom": "*",
        "ext-openssl": "*",
        "ext-libxml": "*",
        "robrichards/xmlseclibs": "^3.1",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "*",
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpstan/phpstan": "*",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": { "psr-4": { "Stea\\FacturaElectronica\\": "src/" } },
    "autoload-dev": { "psr-4": { "Stea\\FacturaElectronica\\Tests\\": "tests/" } },
    "extra": {
        "laravel": { "providers": ["Stea\\FacturaElectronica\\FacturaElectronicaServiceProvider"] }
    },
    "minimum-stability": "stable",
    "config": { "sort-packages": true }
}
